    "source_law": "刑法第287条之二",
    "article": "第287条之二第1款",
    "conditions": "明知他人利用信息网络实施犯罪，为其犯罪提供互联网接入、服务器托管、网络存储、通讯传输等技术支持，或者提供广告推广、支付结算等帮助",
    "conclusion": "构成帮助信息网络犯罪活动罪",
    "evidence_types": ["合同协议", "服务记录", "资金流水", "聊天记录"],
    "weight": 1.0,
    "applicable_scenarios": ["提供技术支持", "提供支付接口", "提供广告推广"],
    "conflicting_rules": []
  },
  {
    "rule_id": "R009",
    "name": "情节严重认定标准",
    "source_law": "帮信解释（法释〔2019〕15号）",
    "article": "第12条第1款",
    "conditions": "为三个以上对象提供帮助；支付结算金额20万元以上；以投放广告等方式提供资金5万元以上；违法所得1万元以上；两年内曾因非法利用信息网络、帮助信息网络犯罪活动受过行政处罚，又实施帮信行为；被帮助对象实施的犯罪造成被害人严重经济损失等情形之一",
    "conclusion": "属于情节严重，应当追究刑事责任",
    "evidence_types": ["银行流水", "审计报告", "前科材料", "被害人陈述"],
    "weight": 1.0,
    "applicable_scenarios": ["提供支付接口", "提供技术支持", "提供广告推广"],
    "conflicting_rules": []
  },
  {
    "rule_id": "R010",
    "name": "其他情节严重情形",
    "source_law": "帮信解释（法释〔2019〕15号）",
    "article": "第12条第2款",
    "conditions": "其他严重扰乱正常网络秩序或者严重影响公民人身、财产安全的情形",
