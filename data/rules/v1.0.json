[
  {
    "rule_id": "R001",
    "name": "推定明知-价格异常",
    "source_law": "最高人民法院、最高人民检察院、公安部《关于办理电信网络诈骗等刑事案件适用法律若干问题的意见（二）》（法发〔2019〕24号）",
    "article": "第11条第1款第(1)项",
    "conditions": "收购、出售、提供他人银行卡、身份证件、U盾、手机卡等的价格显著高于市场价格",
    "conclusion": "可以推定行为人主观上明知他人利用信息网络实施犯罪",
    "evidence_types": ["交易流水", "价格凭证", "聊天记录", "证人证言"],
    "weight": 0.85,
    "applicable_scenarios": ["开卡", "卖卡", "提供U盾", "提供支付接口"],
    "conflicting_rules": []
  },
