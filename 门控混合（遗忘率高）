    np.random.seed(42)
    num_samples = 5000
    seq_len = 30
    
    clause_dist = torch.tensor([0.25, 0.20, 0.15, 0.25, 0.15])
    clause_type = torch.multinomial(clause_dist, num_samples * seq_len, replacement=True).reshape(num_samples, seq_len)
    clause_onehot = nn.functional.one_hot(clause_type, num_classes=5).float()
    
    sent_len = torch.normal(80, 40, (num_samples, seq_len, 1)).clamp(5, 200) / 200.0
    legal_density = torch.normal(0.25, 0.08, (num_samples, seq_len, 1)).clamp(0.05, 0.5)
    money_count = torch.poisson(torch.tensor(1.5)).expand(num_samples, seq_len, 1).clamp(0, 3).float() / 3.0
    long_dep_signal = (torch.rand(num_samples, seq_len, 1) < 0.3).float()
    keyword_features = torch.normal(0, 1, (num_samples, seq_len, 5))
    
    X = torch.cat([clause_onehot, sent_len, legal_density, money_count, long_dep_signal, keyword_features], dim=-1)
    
    has_penalty = (clause_type == 2).any(dim=1)
    has_dispute = (clause_type == 3).any(dim=1)
    has_high_amount = (money_count.mean(dim=1) > 0.5).squeeze()
    
    high_risk = (
        (has_penalty & ~has_dispute) | 
        (has_penalty & has_high_amount) |
        (long_dep_signal[:, 5, 0] > 0.5) |
        ((legal_density.mean(dim=1) > 0.3).squeeze() & ~has_dispute)
    )
    y = high_risk.float()
    input_dim = X.shape[-1]
    
    torch.save((X, y, input_dim), data_file)
    print(f"数据集已保存至：{data_file}")

