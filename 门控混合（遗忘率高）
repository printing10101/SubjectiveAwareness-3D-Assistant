# 2. 定义模型（统一128维隐藏层，单向LSTM）
# ==========================================
HIDDEN_DIM = 128

class LSTMModel(nn.Module):
    def __init__(self, input_dim, hidden_dim=HIDDEN_DIM):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 1),
            nn.Sigmoid()
        )
        
    def forward(self, x):
        out, _ = self.lstm(x)
        return self.classifier(out[:, -1, :]).squeeze()

class PureLNN(nn.Module):
    def __init__(self, input_dim, hidden_dim=HIDDEN_DIM):
        super().__init__()
        self.lnn = CfC(input_dim, hidden_dim)
        self.classifier = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 1),
            nn.Sigmoid()
        )
        
    def forward(self, x):
        out = self.lnn(x)
        if isinstance(out, tuple):
            out = out[0]
        return self.classifier(out[:, -1, :]).squeeze()

class HybridGateFusion(nn.Module):
    def __init__(self, input_dim, hidden_dim=HIDDEN_DIM):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)
        self.lnn = CfC(input_dim, hidden_dim)
        # 门控输入是128+128=256维
        self.gate = nn.Sequential(
            nn.Linear(hidden_dim * 2, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, 2),
            nn.Softmax(dim=-1)
        )
        self.classifier = nn.Linear(hidden_dim, 1)
    
    def forward(self, x):
        lstm_out, _ = self.lstm(x)
        lstm_last = lstm_out[:, -1, :]  # (batch, 128)
        
        lnn_out = self.lnn(x)
        if isinstance(lnn_out, tuple):
            lnn_out = lnn_out[0]
        lnn_last = lnn_out[:, -1, :]  # (batch, 128)
        
        gate_input = torch.cat([lstm_last, lnn_last], dim=-1)  # (batch, 256)
        gate_weights = self.gate(gate_input)  # (batch, 2)
        fused = gate_weights[:, 0:1] * lstm_last + gate_weights[:, 1:2] * lnn_last  # (batch, 128)
        
        return torch.sigmoid(self.classifier(fused)).squeeze()
    # ==========================================
# 3. 训练与评估
# ==========================================
def train_and_eval(model, train_X, train_y, test_X, test_y, epochs=100, lr=0.001, batch_size=64):
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)
    scheduler = torch.optim.lr_scheduler.StepLR(optimizer, step_size=40, gamma=0.5)
    loss_fn = nn.BCELoss()
    
    dataset = torch.utils.data.TensorDataset(train_X, train_y)
    loader = torch.utils.data.DataLoader(dataset, batch_size=batch_size, shuffle=True)
    
    test_acc_history = []
    
    for epoch in range(epochs):
        model.train()
        for batch_x, batch_y in loader:
            optimizer.zero_grad()
            pred = model(batch_x)
            loss = loss_fn(pred, batch_y)
            loss.backward()
            optimizer.step()
        scheduler.step()
        
        model.eval()
        with torch.no_grad():
            test_pred = model(test_X)
            test_acc = ((test_pred > 0.5) == test_y).float().mean().item()
            test_acc_history.append(test_acc)
            
    return test_acc_history

# ==========================================
# 4. 遗忘性测试
# ==========================================
def catastrophic_forgetting_test(model_class, input_dim, seq_len=30, hidden_dim=HIDDEN_DIM, epochs_per_task=40):
    torch.manual_seed(123)
    X_A = torch.rand(500, seq_len, input_dim) * 0.4
    y_A = (X_A[:, -1, 0] > 0.2).float()
    
    torch.manual_seed(456)
    X_B = torch.rand(500, seq_len, input_dim) * 0.6 + 0.4
    y_B = (X_B[:, -1, 0] > 0.7).float()
    
    model = model_class(input_dim, hidden_dim)
    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
    loss_fn = nn.BCELoss()
    
    dataset_A = torch.utils.data.TensorDataset(X_A, y_A)
    loader_A = torch.utils.data.DataLoader(dataset_A, batch_size=32, shuffle=True)
    
    for _ in range(epochs_per_task):
        model.train()
        for bx, by in loader_A:
            optimizer.zero_grad()
            loss = loss_fn(model(bx), by)
            loss.backward()
            optimizer.step()
    
    model.eval()
    with torch.no_grad():
        acc_before = ((model(X_A) > 0.5) == y_A).float().mean().item()
    
    dataset_B = torch.utils.data.TensorDataset(X_B, y_B)
    loader_B = torch.utils.data.DataLoader(dataset_B, batch_size=32, shuffle=True)
    for _ in range(epochs_per_task):
        model.train()
        for bx, by in loader_B:
            optimizer.zero_grad()
            loss = loss_fn(model(bx), by)
            loss.backward()
            optimizer.step()
    
    model.eval()
    with torch.no_grad():
        acc_after = ((model(X_A) > 0.5) == y_A).float().mean().item()
        
    return acc_before, acc_after

