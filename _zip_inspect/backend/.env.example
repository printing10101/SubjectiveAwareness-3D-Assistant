# =============================================================================
# 环境变量配置文件示例 (.env.example)
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置值
# 命令: cp .env.example .env
# =============================================================================


# --- DeepSeek 云端模型配置（推荐）---
# 配置后系统优先使用你自己的 DeepSeek 云端模型；未配置则使用本地规则化兜底，保证可演示。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_TIMEOUT=120

# --- Ollama 配置 ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_UPSTREAM_URL=http://localhost:11434
OLLAMA_ENABLED=false

# --- 服务器配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# --- 运行环境 ---
# development - 开发环境，允许 CORS_ORIGINS 使用通配符(*)
# production  - 生产环境，严禁使用通配符(*)，必须明确指定域名
APP_ENV=development

# --- 数据库配置 ---
DATABASE_URL=sqlite:///./app.db

# --- JWT 认证配置 ---
# 安全要求：
#   - 生产环境必须配置为安全的随机密钥（至少 256 位 / 32 字节）
#   - 未配置或使用默认占位符将导致生产环境应用启动失败
#   - 开发环境未配置时会显示警告，但允许使用占位符继续运行
#
# 生成安全密钥：
#   python ../scripts/generate_jwt_secret.py --env-format
#
# 密钥要求：
#   - 长度 >= 32 字节（64 个十六进制字符）
#   - 使用密码学安全的随机数生成器
#   - 请勿将真实密钥提交到版本控制系统（.gitignore 应包含 .env）
#
# 示例（请替换为生成的真实密钥）：
# JWT_SECRET_KEY=请运行 generate_jwt_secret.py 脚本生成并替换此行
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- 默认管理员账号 ---
# 生产环境必须修改默认密码
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# =============================================================================
# CORS 安全配置
# =============================================================================
# 遵循最小权限原则，仅开放必要的跨域访问权限
#
# 安全注意事项：
# 1. 生产环境(APP_ENV=production)下，CORS_ORIGINS 严禁使用通配符(*)
# 2. 必须明确指定允许访问的前端域名列表
# 3. 仅保留项目实际需要的 HTTP 方法和请求头
# =============================================================================

# --- CORS 允许的来源 ---
# 格式：逗号分隔的完整域名(含协议和端口)
# 开发环境示例: http://localhost:3000,http://127.0.0.1:3000
# 生产环境示例: https://yourdomain.com,https://www.yourdomain.com
# 安全警告: 生产环境使用 * 将导致应用启动时抛出异常并拒绝服务
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- CORS 允许的 HTTP 方法 ---
# 仅保留项目实际使用的方法:
#   GET    - 查询资源
#   POST   - 创建资源、提交表单
#   PUT    - 更新资源
#   DELETE - 删除资源
#   OPTIONS- 预检请求(CORS 标准必需)
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# --- CORS 允许的请求头 ---
# 精确指定允许客户端发送的请求头:
#   Authorization  - JWT 令牌认证
#   Content-Type   - 请求体类型(application/json等)
#   Accept         - 响应内容类型偏好
#   X-Requested-With - AJAX 请求标识
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,X-Requested-With

# =============================================================================
# 日志配置 ---
LOG_LEVEL=DEBUG

# =============================================================================
# Neo4j 图数据库配置（留空则使用内存图存储）---
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- 推理服务器配置 ---
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8001

# =============================================================================
# Sentry 错误追踪与性能监控配置
# =============================================================================
# Sentry 是一个实时错误追踪与监控平台，能够自动捕获未处理异常、记录
# 性能数据、追踪用户会话并提供告警能力。
#
# 启用方式：
#   1. 在 https://sentry.io 注册账号并创建项目（选择 Python/FastAPI 平台）
#   2. 进入 Project -> Settings -> Client Keys (DSN) 复制 DSN
#   3. 将 DSN 配置到下方 SENTRY_DSN 字段
#   4. 重启应用即可生效，错误事件将自动上报到 Sentry
#
# 禁用方式：
#   将 SENTRY_DSN 留空或删除该行，应用将正常运行，不产生任何 Sentry 副作用
#
# 安全说明：
#   - SENTRY_DSN 是公开标识符，可提交到代码仓库（也可使用环境变量管理）
#   - 错误报告中默认不发送个人身份信息（send_default_pii=false）
#   - 敏感字段（密码、token、密钥等）应使用 set_context 前过滤
# =============================================================================

# --- Sentry DSN（必须配置才能启用错误追踪）---
# 格式示例: https://<key>@<org>.ingest.sentry.io/<project_id>
# 留空表示禁用 Sentry，应用正常运行
SENTRY_DSN=

# --- 部署环境标识（用于在 Sentry 平台过滤和分类事件）---
# 建议取值:
#   - development: 本地开发环境
#   - staging: 预发布/测试环境
#   - production: 生产环境
# 留空时将自动使用 APP_ENV 的值
SENTRY_ENVIRONMENT=

# --- 性能追踪采样率（范围 0.0 - 1.0）---
# 控制应用性能数据（请求响应时间、慢查询等）的采样比例
# - 0.0  = 禁用性能追踪
# - 0.1  = 采样 10%（生产环境推荐，控制性能开销在 5% 以内）
# - 0.5  = 采样 50%
# - 1.0  = 全量采样（仅推荐开发/测试环境）
# 建议生产环境设置为 0.1 ~ 0.2
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- 是否在事件中附加堆栈跟踪（建议始终启用）---
# 启用后可获取更完整的错误上下文，便于问题定位
# 取值: true | false
SENTRY_ATTACH_STACKTRACE=true

# --- 是否发送默认个人身份信息（强烈建议生产环境保持 false）---
# 为 true 时 Sentry 会自动收集用户 IP、Cookie 等信息
# 启用 Sentry 用户上下文推荐手动调用 set_user() 而非依赖此选项
# 取值: true | false
SENTRY_SEND_DEFAULT_PII=false

# --- Sentry 事件发送超时（秒）---
# 控制发送错误事件的最大等待时间，避免阻塞应用
SENTRY_TIMEOUT=5.0

# =============================================================================
# 缓存后端配置 (Redis)
# =============================================================================
# 本系统默认使用 Redis 作为缓存后端，支持分布式部署与高并发场景。
# Docker Compose 已包含 redis:7-alpine 服务，可通过 docker-compose up redis 启动。
#
# 生产环境推荐配置:
#   - CACHE_BACKEND=redis
#   - REDIS_URL=redis://:<password>@<host>:6379/0
# 单机/本地开发:
#   - CACHE_BACKEND=file
#   - REDIS_URL=redis://localhost:6379/0
# =============================================================================

# --- 缓存后端类型 ---
# 取值: redis | file
# - redis: 生产环境推荐，支持分布式部署与 TTL 精确过期
# - file : 单机开发/降级方案，基于本地 JSON 文件，无网络开销但不支持分布式
# 默认值: redis
# 生产环境建议: redis
CACHE_BACKEND=redis

# --- Redis 服务连接 URL ---
# 格式: redis://[user:password@]host:port/db
# - 本地开发: redis://localhost:6379/0
# - Docker 容器内（service-to-service）: redis://redis:6379/0
# - 生产环境: redis://:<password>@<your-redis-host>:6379/0
# 注意: 当 Redis 设置了密码时，必须在 URL 中包含密码部分（@ 前缀表示空用户名）
# 默认值: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# --- 缓存键前缀 ---
# 在共享 Redis 实例中用于隔离不同应用/不同环境的缓存命名空间
# 推荐格式: "<app-name>:<env>:"，例如 "legal-analysis:prod:"
# 生产环境建议: legal-analysis:prod:
# 留空将使用 AnalysisConfig 中的默认值
CACHE_KEY_PREFIX=legal-analysis:dev:

# --- Redis 连接池与重试参数（可选，使用默认值即可）---
# 连接池最大连接数，控制并发访问上限
REDIS_MAX_CONNECTIONS=20
# 操作失败时的最大重试次数（仅用于连接超时/断连时的自动恢复）
REDIS_RETRY_MAX_ATTEMPTS=3
# 重试之间的间隔（秒）
REDIS_RETRY_DELAY=0.5
# Socket 读写操作超时（秒）
REDIS_SOCKET_TIMEOUT=5.0
# Socket 连接建立超时（秒）
REDIS_SOCKET_CONNECT_TIMEOUT=2.0
