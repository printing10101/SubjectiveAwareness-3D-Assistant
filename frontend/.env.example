# =============================================================================
# 前端环境变量配置示例 (.env.example)
# =============================================================================
# 复制此文件为 .env 或 .env.development / .env.production 并根据实际环境修改
# Vite 会自动加载 .env、.env.development、.env.production 等文件
# 注意：所有暴露给前端的变量必须以 VITE_ 前缀开头
# =============================================================================

# --- API 后端地址（开发环境通过 Vite proxy 转发到 /api）---
VITE_API_BASE_URL=/api

# --- 应用基本配置 ---
VITE_APP_TITLE=帮信罪主观明知智能分析系统

# =============================================================================
# Sentry 错误追踪与性能监控配置
# =============================================================================
# Sentry 是实时错误追踪与性能监控平台，能够捕获前端未处理异常、记录
# 性能数据、追踪用户会话并提供告警能力。
#
# 启用方式：
#   1. 在 https://sentry.io 注册账号并创建项目（选择 Vue 平台）
#   2. 进入 Project -> Settings -> Client Keys (DSN) 复制 DSN
#   3. 将 DSN 配置到下方 VITE_SENTRY_DSN 字段
#   4. 重启 Vite 开发服务器或重新构建
#
# 禁用方式：
#   将 VITE_SENTRY_DSN 留空或删除该行，应用将正常运行，不产生任何 Sentry 副作用
#
# 安全说明：
#   - VITE_SENTRY_DSN 是公开标识符，会被打包到前端代码中
#   - 不要在 Sentry 事件中携带任何敏感信息（密码、token、密钥等）
#   - 错误报告中默认不发送个人身份信息（sendDefaultPii=false）
# =============================================================================

# --- Sentry DSN（必须配置才能启用错误追踪）---
# 格式示例: https://<key>@<org>.ingest.sentry.io/<project_id>
# 留空表示禁用 Sentry，应用正常运行
VITE_SENTRY_DSN=

# --- 部署环境标识（用于在 Sentry 平台过滤和分类事件）---
# 建议取值:
#   - development: 本地开发环境
#   - staging: 预发布/测试环境
#   - production: 生产环境
# 留空时将自动使用 Vite 的 MODE 值（development / production）
VITE_SENTRY_ENVIRONMENT=

# --- 性能追踪采样率（范围 0.0 - 1.0）---
# 控制前端性能数据（页面加载、路由切换、API 调用等）的采样比例
# - 0.0  = 禁用性能追踪
# - 0.1  = 采样 10%（生产环境推荐）
# - 0.5  = 采样 50%
# - 1.0  = 全量采样（仅推荐开发/测试环境）
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# --- 会话重放采样率（范围 0.0 - 1.0）---
# 启用 Sentry Replay 功能，可录制用户操作会话，便于错误复现
# - 0.0  = 禁用会话录制（默认，保护用户隐私）
# - 0.1  = 录制 10% 的会话
# - 1.0  = 录制全部会话（开发环境可使用）
# 录制时所有文本和媒体将被自动遮蔽（maskAllText + blockAllMedia）
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0

# --- 错误时重放采样率（范围 0.0 - 1.0）---
# 发生错误时，录制错误前后一段时间的用户会话
# - 0.0  = 错误时也不录制
# - 1.0  = 发生任何错误都录制（推荐配置，便于问题排查）
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
